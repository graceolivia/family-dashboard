# Timezone — used server-side and client-side
TZ_NAME=America/New_York
NEXT_PUBLIC_TZ_NAME=America/New_York

# Weather (Open-Meteo — no API key needed)
WEATHER_LAT=40.85
WEATHER_LON=-73.94

# Google Calendar — comma-separated private ICS subscription URLs
ICS_URLS=https://calendar.google.com/calendar/ical/EXAMPLE1/private-XXXX/basic.ics,https://calendar.google.com/calendar/ical/EXAMPLE2/private-XXXX/basic.ics

# Labels matching ICS_URLS order (used in color legend)
ICS_LABELS=Grace,Family

# Optional: override calendar colors (hex values, comma-separated, matching ICS_URLS order)
# If omitted, colors are auto-assigned from a built-in palette
# ICS_COLORS=#6366f1,#10b981

# Upstash Redis (from Vercel integration)
UPSTASH_REDIS_REST_URL=https://YOUR_URL.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# Shared password for Basic Auth (protects all routes)
DASHBOARD_PASSWORD=changeme
